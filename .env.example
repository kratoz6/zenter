# HallMate — local environment variables for Playwright e2e tests.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Override the live deployment URL when targeting a preview build or local dev.
# PLAYWRIGHT_BASE_URL=http://localhost:8080

# Firebase test phone number — must be configured in:
#   Firebase Console → Authentication → Sign-in method → Phone → "Phone numbers for testing"
# Enter the 10 digits only, no +91 prefix.
PLAYWRIGHT_TEST_PHONE=

# The matching 6-digit verification code configured alongside the test phone.
PLAYWRIGHT_TEST_OTP=
